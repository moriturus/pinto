error-prefix = error:
initialized-board-at = Initialized pinto board at { $path }
already-initialized = Already initialized: { $path } already exists
created = Created { $id } { $title }
no-backlog-items = No backlog items.
no-actionable-items = No actionable backlog items.
moved = Moved { $id } to { $status }
acceptance-criteria-incomplete = warning: { $id } moved to the done column with incomplete Acceptance Criteria ({ $progress })
reordered = Reordered { $id }
updated = Updated { $id } { $title }
no-changes-to = No changes to { $id }
archived = Archived
restored = Restored
deleted = Deleted
created-sprint = Created sprint { $id } { $title }
updated-sprint = Updated sprint { $id }
deleted-sprint = Deleted sprint { $id }
started-sprint = Started sprint { $id }
closed-sprint = Closed sprint { $id }
assigned-to-sprint = Assigned { $id } to sprint { $sprint }
unassigned-from-sprint = Unassigned { $id } from sprint { $sprint }
no-sprints = No sprints.
dependency-added = { $id } now depends on { $dependency }.
dependency-cycle-warning = warning: this dependency introduces a cycle involving { $id } and { $dependency }
dependency-cycle-warning-generic = warning: this dependency introduces a cycle
dependency-removed = { $id } no longer depends on { $dependency }.
link-already-linked = { $id }: already linked (no change)
link-added = { $id }: linked { $commits }
link-no-matching-commit = { $id }: no matching commit to unlink
link-removed = { $id }: unlinked { $commits }
link-no-new-commits = No new commits linked.
link-commit-linked = { $id }: linked { $commit }
link-summary = Linked { $count } commit(s).
dod-unset = No common DoD set. Set one with `pinto dod set <text>`.
dod-updated = Updated common DoD.
dod-cleared = Cleared common DoD.
dod-no-common-to-clear = No common DoD to clear.
migration-completed = Migrated { $items } item(s) and { $sprints } sprint(s) from { $from } to { $to }.
migration-backend-updated = Storage backend is now { $backend } (updated .pinto/config.toml).
migration-already-using = Already using { $backend }; nothing to migrate.
migration-sqlite-unavailable = this binary was built without the sqlite backend; rebuild with `--features sqlite`
wip-limit-exceeded = warning: WIP limit exceeded in '{ $column }': { $count } item(s) > limit { $limit }; move items out, raise the limit in config.toml, or pass --no-wip-check
orphaned-items-warning = warning: { $count } item(s) are in columns not defined in config.toml ({ $ids }); move them to a valid column or add the column to `columns`
rebalance-already-balanced = Ranks already balanced ({ $count } item(s), max rank length { $max_length }).
rebalance-dry-run = Would rebalance { $changed }/{ $total } item(s) (max rank length { $before } -> { $after }).
rebalance-completed = Rebalanced { $changed }/{ $total } item(s) (max rank length { $before } -> { $after }).
doctor-healthy = Board is healthy.
doctor-issues = Found { $count } unresolved board issue(s).
doctor-fixed = Fixed: { $description }
doctor-issue = [{ $kind }] { $location}: { $detail} Repair: { $repair}
doctor-kind-dangling-dependency = dangling dependency
doctor-kind-dangling-parent = dangling parent
doctor-kind-dangling-sprint = dangling sprint
doctor-kind-parent-cycle = parent cycle
doctor-kind-dependency-cycle = dependency cycle
doctor-kind-duplicate-id = duplicate ID
doctor-kind-issued-id = issued ID history
doctor-kind-invalid-status = invalid workflow state
doctor-kind-rank-anomaly = rank anomaly
doctor-kind-collision = storage collision
doctor-kind-malformed-record = malformed record
doctor-kind-filename = filename mismatch
invalid-capacity-options = daily-hours, holidays, and deduction-factor must be provided together
failed-to-action = failed to { $action } { $id }
shell-parse-error = error: { $error }
sprint-add-requires-item-or-status = sprint add requires an item ID or --status
error-invalid-item-id = invalid item id: { $value } (expected an ASCII-letter PREFIX followed by `-` and a decimal NUMBER)
error-invalid-rank = invalid rank: { $value } (expected non-empty base-36 chars `0-9a-z`)
error-invalid-automation-plan = invalid automation plan (expected a commands array; API keys are not accepted)
error-automation-plan-source = cannot read automation plan source { $path}: { $message }; provide inline JSON, a readable file path, or `-` for standard input
error-unknown-status = unknown status: { $status } is not a column in the workflow
error-empty-title = title must not be empty
error-invalid-search-pattern = invalid search pattern: { $pattern }
error-invalid-filter-option = invalid filter option: { $option }
error-nothing-to-update = no fields to update
error-empty-dod = definition of done must not be empty
error-invalid-template-name = invalid template name: { $name } (expected non-empty ASCII alphanumeric, `-`, or `_`)
error-template-not-found = template not found: { $kind }/{ $name } (create { $path })
error-template-unreadable = template cannot be read: { $path } ({ $message }; fix or replace this plain-text file)
error-not-found = backlog item not found: { $id }
error-referenced-item = cannot remove { $item }: referenced by { $references }; remove these parent/dependency links first
error-invalid-sprint-id = invalid sprint id: { $id } (expected non-empty ASCII alphanumeric, `-`, or `_`)
error-invalid-sprint-state = invalid sprint state: { $state } (expected `planned`, `active`, or `closed`)
error-empty-sprint-title = sprint title must not be empty
error-empty-sprint-goal = sprint goal must be set before starting the sprint
error-invalid-sprint-transition = invalid sprint transition: { $from } -> { $to } (allowed: planned -> active -> closed)
error-sprint-not-found = sprint not found: { $id }
error-sprint-exists = sprint already exists: { $id } (use `sprint edit`/`remove` to manage it)
error-sprint-closed = cannot assign a PBI to closed sprint { $id } (assign it to a planned or active sprint instead; use `sprint unassign { $id } <item-id>` to remove an existing assignment)
error-invalid-sprint-period = invalid sprint period: start { $start } is after end { $end }
error-invalid-daily-work-hours = daily work hours must be a finite number greater than or equal to 0 (got { $value })
error-invalid-deduction-factor = deduction factor must be a finite number from 0 to 1 (got { $value })
error-invalid-sprint-holidays = holiday days ({ $holidays }) must not exceed the { $calendar_days } calendar day(s) in the sprint period
error-sprint-capacity-period-unset = sprint { $id } has no start/end dates (set them with `sprint edit { $id } --start <YYYY-MM-DD> --end <YYYY-MM-DD>` before setting capacity)
error-sprint-capacity-unset = sprint { $id } has no capacity settings (set them with `sprint capacity { $id } --daily-hours <HOURS> --holidays <DAYS> --deduction-factor <0..1>`)
error-sprint-period-unset = sprint { $id } has no start/end dates (set them with `sprint edit { $id } --start <YYYY-MM-DD> --end <YYYY-MM-DD>`)
error-sprint-empty = sprint { $id } has no assigned items (assign one with `sprint add { $id } <item-id>`)
error-not-in-sprint = { $item } is not assigned to sprint { $sprint }
error-parent-cycle = setting parent of { $child } to { $parent } would create a cycle
error-not-initialized = not a pinto board: { $path } not found after checking this directory and its ancestors (run `pinto init`, or use `--dir PATH` / `PINTO_DIR`)
error-io = i/o error at { $path }: { $message }
error-parse = failed to parse { $path }: { $message }
error-missing-frontmatter = missing `+++` frontmatter delimiter in { $path }
error-unsupported-sqlite-schema = unsupported SQLite schema at { $path }: found version { $found }, but pinto supports version { $supported }; upgrade or downgrade pinto to a compatible version, or recreate the database (automatic migration is not available)
error-self-reference = cannot reorder { $id } relative to itself
error-not-sibling = cannot reorder { $item } relative to { $reference }: they are not siblings (same parent and column); use `edit --parent` to regroup
error-task = background task failed: { $message }
error-git = git backend error: { $message }
error-editor-not-set = no editor configured: set $VISUAL or $EDITOR, or provide content directly (e.g. `pinto add <title> --body ...` or `pinto edit <id> --title ...`)
error-editor-launch = failed to launch editor `{ $editor }`: { $message }
error-editor-invalid = edited content is invalid: { $message }
error-locked = board is locked by another process ({ $path }); retry shortly, or remove the file if no pinto is running
automation-command-valid = Command { $index } ({ $command }): valid; changes planned.
automation-command-invalid = Command { $index } ({ $command }): invalid; no changes made.
automation-command-failed = Command { $index } ({ $command }): failed: { $error }
automation-command-skipped = Command { $index } ({ $command }): skipped after a previous failure.
automation-dry-run-completed = Dry run validated { $total } command(s); no changes made.
automation-completed = Automated { $total } command(s).
automation-partial-failure = Automation stopped after command { $index } ({ $command }); { $completed } completed, { $failed } failed, { $skipped } skipped.
automation-invalid-command-arguments = invalid command arguments; see `pinto <command> --help`
automation-not-executed-after-failure = not executed after a previous command failed
automation-not-validated-after-failure = not validated after a previous command failed
automation-dry-run-git-init-failed = failed to initialize dry-run Git repository: { $message }
automation-dry-run-workspace-unavailable = could not create a unique dry-run workspace
automation-command-exited = command exited with status { $status }
already-in-interactive-shell = error: already in an interactive shell
kanban-details-title = Details
kanban-popup-hints = {$close}: close  {$scroll_down}/{$scroll_up}: scroll  {$select_left}/{$select_right}/{$select_up}/{$select_down}: select  {$edit}: edit
kanban-help-title = Help
kanban-help-entries =
    {$shell}: return to shell
    {$move}: move item
    {$reorder}: reorder item
    {$add}: add item
    {$parent}: set/clear parent
    {$dependency_add}: add dependency
    {$dependency_remove}: remove dependency
    {$edit}: edit item
    {$reload}: reload board
    {$maximize}: maximize column
    {$search}: search
    {$regex_search}: regex search
kanban-help-clear-filter = {$clear_filter}: clear search filter
kanban-no-changes = No changes to
kanban-editor-failed = Could not launch editor:
kanban-edit-failed = Could not apply edit:
kanban-wip-exceeded = ⚠ WIP limit exceeded:
kanban-no-editor = $EDITOR/$VISUAL is not set (move: H/L, reorder: K/J)
kanban-key-hints = {$cursor}: cursor  {$expand}: expand  {$details}: details  {$quit}: quit
kanban-help-hint = {$help}: help
kanban-add-title-prompt = + title:
kanban-add-body-prompt = + body:
kanban-add-parent-prompt = + parent (select or type ID; blank skips):
kanban-add-dependencies-prompt = + dependencies (select or type IDs; blank skips):
kanban-dependency-add-prompt = + dependency target (select or type ID):
kanban-dependency-remove-prompt = - dependency target (select or type ID):
kanban-empty-title = Title must not be empty.
kanban-empty-dependency = Dependency ID must not be empty.
kanban-dependency-added = Added dependency {$dependency} to {$source}.
kanban-dependency-removed = Removed dependency {$dependency} from {$source}.
kanban-dependency-cycle-warning = warning: this creates a dependency cycle
kanban-parent-prompt = + parent target (select or type ID; blank clears):
kanban-parent-set = Set parent of {$source} to {$parent}.
kanban-parent-cleared = Cleared parent of {$source}.
kanban-active-filter = filter: {$pattern}
kanban-active-regex-filter = regex: {$pattern}
kanban-dependency-legend = ⊸ depends on  ⊷ depended on by  ⊸! unresolved dependency
kanban-column-range = { $left } columns { $start }-{ $end }/{ $total } { $right }
kanban-empty-columns = No columns. Run `pinto init` to initialize this directory.
kanban-quit-body = y / Esc: yes    n: no
kanban-quit-prompt = Quit pinto?
kanban-no-body = (no body)
kanban-no-selection = No item selected in this column.
kanban-terminal-init-failed = Could not initialize the terminal (run from a TTY): { $error }
edit-guidance =
    # pinto: saving applies your edits; exit without changes to cancel.
    # id / status / rank / depends_on / timestamps are managed by pinto, so edits here are ignored.
    # (change status with `move`, rank with `reorder`, and dependencies with `dep`.)
cli-heading-commands = Commands
cli-heading-arguments = Arguments
cli-heading-options = Options
cli-command-pinto = A lightweight CLI/TUI backlog and kanban board for Scrum.
cli-arg-pinto-dir = Board project directory override. Accepts a project path or its `.pinto` directory; `PINTO_DIR` is used when omitted.
cli-command-pinto-init = Initialize a board in the current directory.
cli-command-pinto-add = Add a PBI to the backlog.
cli-command-pinto-list = List backlog PBIs.
cli-command-pinto-next = Display the highest-ranked actionable PBIs that are ready to start.
cli-command-pinto-show = Show details for one or more PBIs by ID.
cli-arg-pinto-show-ids = IDs of the PBIs to display in the specified order.
cli-command-pinto-move = Move one or more PBIs to another status column.
cli-command-pinto-reorder = Reorder a PBI without changing its status.
cli-command-pinto-edit = Update fields on an existing PBI.
cli-command-pinto-remove = Archive or permanently remove one or more PBIs.
cli-command-pinto-dep = Manage dependencies between PBIs.
cli-command-pinto-link = Add, remove, or discover Git commits linked to PBIs.
cli-command-pinto-dod = View, set, or clear the shared Definition of Done.
cli-command-pinto-sprint = Manage sprints.
cli-command-pinto-board = Display the board (PBI by column).
cli-command-pinto-cycletime = Report cycle time and lead time for completed PBIs.
cli-command-pinto-rebalance = Rebalance oversized ranks while preserving order.
cli-command-pinto-migrate = Migrate the storage backend.
cli-command-pinto-doctor = Check board integrity and report actionable repairs.
cli-arg-pinto-doctor-fix = Apply safe mechanical repairs before the final scan.
cli-command-pinto-automate = Run an AI-generated structured plan as pinto commands.
cli-arg-pinto-automate-plan = Inline JSON, a readable plan file path, or `-` for standard input.
cli-arg-pinto-automate-dry_run = Validate every command and report planned changes without modifying the board.
cli-arg-pinto-automate-json = Output a structured result instead of human-readable messages.
cli-command-pinto-shell = Start the interactive shell.
cli-command-pinto-kanban = Start the interactive kanban board.
cli-command-pinto-completion = Generate a shell completion script.
cli-command-pinto-sprint-new = Create a new sprint in the planned state.
cli-command-pinto-sprint-start = Start a sprint, moving it from planned to active.
cli-command-pinto-sprint-close = Close a sprint, moving it from active to closed.
cli-command-pinto-sprint-add = Assign a PBI to a sprint, or assign ranked PBIs from a workflow status in bulk.
cli-command-pinto-sprint-remove = Remove a sprint and release its assigned PBIs.
cli-command-pinto-sprint-unassign = Unassign a PBI from its sprint.
cli-command-pinto-sprint-list = List sprints.
cli-command-pinto-sprint-burndown = Draw a sprint burndown chart in the terminal.
cli-command-pinto-sprint-velocity = Report completed points by sprint.
cli-command-pinto-sprint-capacity = Set or show a sprint's available work time.
cli-arg-pinto-sprint-add-sprint_id = The ID of the target sprint (for example, `S-1`).
cli-arg-pinto-sprint-add-item_id = ID of the PBI to assign; omit it when using `--status`.
cli-arg-pinto-sprint-add-status = Assign PBIs in this workflow status, in backlog rank order.
cli-arg-pinto-sprint-add-limit = Maximum number of new assignments; omit to assign every match.
cli-command-pinto-dep-add = Add a dependency from `<id>` to `<depends-on>`.
cli-command-pinto-dep-rm = Remove the dependency from `<id>` to `<depends-on>`.
cli-command-pinto-link-add = Add related commit SHA values to a PBI.
cli-command-pinto-link-rm = Remove related commit SHA values from a PBI.
cli-command-pinto-link-sync = Synchronize Git commit links by matching PBI IDs in commit messages.
cli-command-pinto-dod-set = Set the shared Definition of Done.
cli-command-pinto-dod-clear = Clear the shared Definition of Done.
cli-arg-pinto-next-count = Maximum number of actionable PBIs to display.
cli-arg-pinto-next-sprint = Restrict candidates to the specified Sprint ID.
cli-arg-pinto-next-json = Output machine-readable JSON instead of human-readable formatting.
cli-arg-pinto-add-title = Required PBI title.
cli-arg-pinto-add-points = Story points.
cli-arg-pinto-add-labels = Labels to set. Multiple values can follow one option or be supplied with repeated options.
cli-arg-pinto-add-sprint = Sprint to assign.
cli-arg-pinto-add-body = Body text, such as acceptance criteria.
cli-arg-pinto-add-edit = Open an editor and use the saved contents as the body; `--template` supplies its initial contents.
cli-arg-pinto-add-template = Item body template name from `.pinto/templates/item/<name>.md`.
cli-arg-pinto-edit-labels = Labels to set, replacing the existing set. Multiple values can follow one option or be supplied with repeated options.
cli-arg-pinto-kanban-column = Display only the specified workflow columns. Multiple values may follow one option or be repeated; explicit values override [tui].hidden_columns.
cli-arg-pinto-kanban-maximize = Start with the selected column maximized.
cli-arg-pinto-kanban-sprint = Filter cards by assigned Sprint.
cli-arg-pinto-kanban-label = Filter cards by one or more labels. Multiple labels use OR by default; use --all-labels for AND.
cli-arg-pinto-kanban-all_labels = Require every label supplied to --label instead of matching any label.
